Как на уровне БД можно реализовать ограничение «У одного ингредиента может быть от 1 до 4 потенциальных эффектов»?
create or replace trigger tgr_mm_Spices_Effect
before insert or update on mm_Spices_Effect
for each row
begin
    select case 
        when exists( select 
                            ID_spice, count(ID_effect) 
                     from mm_Spices_Effect 
                     where ID_spice = :new.ID_spice 
                     group by ID_spice having count(ID_effect) = 4
                   )        
    then 1 --если уже 4 эфекта
    else 0
    end into flag from dual;
  if ( flag = 1) then
    raise_application_error('-20000','Spice with id='||:new.ID_spice||' already has 4 effects');
  end if;
END;
