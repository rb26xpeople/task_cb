Написать SQL-запрос, который возвращает составы зелий, имеющих 5 или более эффектов

--По условию не указано, но будем считать что все ингредиенты в зелье уникальны
--все возможные варинанты : 
with variants as (  
                    --2 ингредиента
                    select p1.ID_spice as p1_id, p2.ID_spice as p2_id, 0 as p3_id --не null тк может привести к строке и далее второй Union даст ошибку
                    from Spices p1
                             join Spices p2 on p1.ID_spice != p2.ID_spice 
                    union all
                    --3 ингредиента
                    select p1.ID_spice, p2.ID_spice, p3.ID_spice
                    from Spices p1
                            join Spices p2 on p2.ID_spice != p1.ID_spice
                            join Spices p3 on p3.ID_spice != p1.ID_spice and p3.ID_spice != p2.ID_spice
                )

select p1_id, p2_id , p3_id , count(distinct ID_effect) as count_effect 
from variants  
join mm_Spices_Effect on mm_Spices_Effect in (p1_id,p2_id,p3_id)
group by p1_id, p2_id , p3_id
having count(distinct ID_effect) >= 5;


